# Copy this file to .env and fill in your values.
# Scripts read these as environment variables. Export them in your shell before running scripts.

# Azure OpenAI / Foundry endpoint (required)
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com
AZURE_OPENAI_API_KEY=your-api-key-here

# Azure resource coordinates (required for deploy_model.py)
AZURE_SUBSCRIPTION_ID=your-subscription-id
AZURE_RESOURCE_GROUP=your-resource-group
AZURE_COGSERVICES_ACCOUNT=your-cogservices-account-name

# Optional: Project /v1/ endpoint (preferred for FT operations — see SKILL.md)
# OPENAI_BASE_URL=https://YOUR-RESOURCE.services.ai.azure.com/api/projects/YOUR-PROJECT/openai/v1/

# Optional: Data Designer API key (required per-shell for DD CLI)
# AZURE_FOUNDRY_API_KEY=your-foundry-api-key

# Optional: Windows encoding fix for Data Designer (Rich terminal output)
# PYTHONIOENCODING=utf-8

# Optional: Path to az CLI if not on PATH
# AZ_CLI_PATH=C:\Program Files (x86)\Microsoft SDKs\Azure\CLI2\wbin\az.cmd
